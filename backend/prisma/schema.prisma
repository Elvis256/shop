generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  phone         String?
  role          UserRole @default(CUSTOMER)
  emailVerified Boolean  @default(false)
  isBlocked     Boolean  @default(false)
  wishlistPin   String?  // 4-6 digit PIN for wishlist privacy
  googleId      String?  @unique
  avatarUrl     String?
  smsOptIn      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  orders            Order[]
  wishlist          WishlistItem[]
  reviews           Review[]
  addresses         Address[]
  cart              Cart?
  passwordReset     PasswordReset?
  emailVerification EmailVerification?
  refreshTokens     RefreshToken[]
  activityLogs      ActivityLog[]
  returnRequests    ReturnRequest[]
  supportTickets    SupportTicket[]
  loyaltyAccount    LoyaltyAccount?
  referralCode      ReferralCode?
  referredBy        Referral?        @relation("ReferredUser")
  twoFactorAuth     TwoFactorAuth?
  affiliate         Affiliate?
  backInStockSubs   BackInStockSub[]
  productQuestions  ProductQuestion[]
  productAnswers    ProductAnswer[]
  storeCredit       StoreCredit?
  reviewImages      ReviewImage[]
  subscriptions     Subscription[]
  pushSubscriptions PushSubscription[]
  browseHistory     BrowseEvent[]
  layawayPlans      LayawayPlan[]
  segmentTags       String[]
  shareDiscounts    ShareDiscount[]
  groupBuyJoined    GroupBuyParticipant[]
  dailyCheckIns     DailyCheckIn[]
  priceSlashes      PriceSlash[]
  seller            Seller?
  buyerConversations Conversation[] @relation("BuyerConversations")
  disputes          Dispute[]      @relation("BuyerDisputes")
  registries        Registry[]
  restockReminders  RestockReminder[]
  checkoutAttempts  CheckoutAttempt[]
  priceDropAlerts   PriceDropAlert[]
  orderHistoryDays  Int?              // Auto-delete order history after N days (null = keep forever)

  @@index([createdAt])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([expiresAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  isSubscribed Boolean  @default(true)
  source       String?  // where they signed up (footer, popup, checkout)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Address {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  street        String
  city          String
  county        String?
  postalCode    String?
  country       String  @default("Uganda")
  isDefault     Boolean @default(false)
  deliveryAlias String? // Name shown on package label instead of real name
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)
  currency    String   @default("UGX")
  rating      Decimal  @default(0) @db.Decimal(2, 1)
  reviewCount Int      @default(0)
  sku         String?  @unique
  barcode     String?

  // Flash sale
  flashSalePrice  Decimal?  @db.Decimal(10, 2)
  flashSaleEndsAt DateTime?

  // Daily Deal
  isDailyDeal     Boolean   @default(false)
  dailyDealPrice  Decimal?  @db.Decimal(10, 2)
  dailyDealDate   DateTime?

  // Pre-order
  isPreOrder      Boolean   @default(false)
  preOrderDate    DateTime? // Expected availability date
  
  // Subscription
  isSubscribable  Boolean   @default(false)
  subscriptionDiscount Decimal? @db.Decimal(5, 2) // % off for subscribers

  // Video
  videoUrl    String?
  
  // Inventory
  stock           Int     @default(0)
  reservedStock   Int     @default(0) // Stock reserved during checkout
  lowStockAlert   Int     @default(5)
  trackInventory  Boolean @default(true)
  allowBackorder  Boolean @default(false)
  
  // Media
  images      ProductImage[]
  
  // Organization
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags        String[]
  
  // Status
  status      ProductStatus @default(DRAFT)
  featured    Boolean       @default(false)
  
  // Badges & Highlights
  isNew         Boolean   @default(false)
  isBestseller  Boolean   @default(false)
  badgeText     String?   // Custom badge like "Limited Edition"
  
  // Variants
  hasVariants   Boolean   @default(false)
  variants      ProductVariant[]
  
  // Shipping / Physical
  weight          Decimal?  @db.Decimal(10, 2) // Weight in grams
  
  // Specifications (structured key-value pairs)
  specifications  Json?     // e.g. [{ key: "Material", value: "Gel" }, ...]

  // SEO
  metaTitle       String?
  metaDescription String?

  // Moderation
  moderationNote  String?
  moderatedBy     String?

  // Marketplace seller (null = platform-owned product)
  sellerId    String?
  seller      Seller?   @relation(fields: [sellerId], references: [id], onDelete: SetNull)

  // AliExpress Dropshipping (null = own product, set = dropshipped)
  aliexpressProductId String?
  aliexpressUrl       String?
  aliexpressCost      Decimal?  @db.Decimal(10, 2) // Supplier price in USD
  markupType          MarkupType? // PERCENTAGE or FIXED
  markupValue         Decimal?  @db.Decimal(10, 2) // Markup amount or percentage
  aliexpressAutoSync  Boolean   @default(false)
  lastSyncedAt        DateTime?

  // CJ Dropshipping (null = not from CJ)
  cjProductId   String?
  cjUrl         String?
  cjCost        Decimal?  @db.Decimal(10, 2) // CJ supplier price in USD
  cjAutoSync    Boolean   @default(false)

  // Auto-restock reminder (for consumables like lube, skincare)
  avgDurationDays Int?    // How many days before product runs out

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  cartItems        CartItem[]
  orderItems       OrderItem[]
  wishlist         WishlistItem[]
  reviews          Review[]
  stockAlerts      StockAlert[]
  aliexpressOrders AliExpressOrder[]
  cjOrders         CJOrder[]
  backInStockSubs  BackInStockSub[]
  questions        ProductQuestion[]
  bundleItems      BundleItem[]
  priceTiers       PriceTier[]
  subscriptions    Subscription[]
  browseEvents     BrowseEvent[]
  shareDiscounts   ShareDiscount[]
  groupBuys        GroupBuy[]
  priceSlashes     PriceSlash[]
  registryItems    RegistryItem[]
  restockReminders RestockReminder[]
  conversations    Conversation[]
  priceDropAlerts  PriceDropAlert[]
  promotions       ProductPromotion[]
  layawayPlans     LayawayPlan[]

  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@index([sellerId])
  @@index([price])
  @@index([createdAt])
  @@index([flashSaleEndsAt])
  @@index([status, categoryId, createdAt])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String   // e.g., "Large / Pink"
  sku         String?  @unique
  price       Decimal? @db.Decimal(10, 2) // Override product price if set
  stock       Int      @default(0)
  reservedStock Int    @default(0) // Stock reserved during checkout
  
  // Variant attributes
  size        String?  // S, M, L, XL, etc.
  color       String?  // Pink, Black, etc.
  material    String?  // Silicone, Leather, etc.
  weight      Decimal? @db.Decimal(10, 2) // Weight in grams
  height      String?  // e.g., "15cm"
  dimensions  String?  // e.g., "10x5x3cm"
  description String?  @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  position  Int     @default(0)

  @@index([productId])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    Product[]
  affiliateProducts AffiliateProduct[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?    @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([createdAt])
  @@index([updatedAt])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)
  
  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Customer info (for guest checkout)
  customerName    String
  customerEmail   String
  customerPhone   String?
  
  // Shipping
  shippingAddress String      @db.Text
  shippingMethod  String?
  shippingCost    Decimal     @default(0) @db.Decimal(10, 2)
  trackingNumber  String?
  
  // Pricing
  subtotal        Decimal     @db.Decimal(10, 2)
  discount        Decimal     @default(0) @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  currency        String      @default("UGX")
  
  // Status
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  
  // Options
  discreet        Boolean     @default(true)
  notes           String?     @db.Text

  // Gift order
  isGift              Boolean   @default(false)
  giftRecipientPhone  String?   // Recipient's phone — gets WhatsApp with address request
  giftMessage         String?   @db.Text
  giftToken           String?   @unique // Secure token for recipient to confirm address
  giftAddressSet      Boolean   @default(false)

  // Guest checkout auto-delete
  guestDataExpiresAt  DateTime?

  // Delivery time slot
  deliveryTimeSlot    String?

  // Delivery OTP (pay-on-delivery verification)
  deliveryOtp         String?
  deliveryOtpExpiry   DateTime?
  deliveryConfirmedAt DateTime?
  deliveryConfirmedBy String?

  // Coupon
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])

  items           OrderItem[]
  payments        Payment[]
  timeline        OrderEvent[]
  mobileMoneyTxns MobileMoneyTransaction[]
  stockReservations StockReservation[]
  returnRequests  ReturnRequest[]
  aliexpressOrders AliExpressOrder[]
  cjOrders         CJOrder[]
  installmentPlan InstallmentPlan?
  checkoutAttempts CheckoutAttempt[]
  escrow          EscrowTransaction?
  disputes        Dispute[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerEmail])
  @@index([status])
  @@index([userId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([paymentStatus, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  name      String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  sellerId  String? // Snapshot of product seller at time of order
  seller    Seller? @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  commission Decimal? @db.Decimal(10, 2) // Platform commission amount

  @@index([productId])
  @@index([orderId])
  @@index([sellerId])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// Stock reservation during checkout (expires after timeout)
model StockReservation {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  variantId   String?
  quantity    Int
  expiresAt   DateTime
  released    Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  @@index([expiresAt, released])
  @@index([orderId])
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider  String        @default("flutterwave")
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  flwTxId   String?
  flwRef    String?
  amount    Decimal       @db.Decimal(10, 2)
  currency  String        @default("UGX")
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([orderId])
}

model WishlistItem {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  collectionName String   @default("Wishlist")
  createdAt      DateTime @default(now())

  @@unique([userId, productId, collectionName])
}

model Review {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating      Int
  title       String?
  content     String?  @db.Text
  verified    Boolean  @default(false)
  approved    Boolean  @default(false)
  isAnonymous Boolean  @default(true)  // Default: hide real name
  displayCity String?  // e.g. "Kampala" — shown instead of real name
  sellerReply     String?    @db.Text
  sellerRepliedAt DateTime?
  images      ReviewImage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([reviewId])
}

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique
  description     String?
  type            DiscountType
  value           Decimal      @db.Decimal(10, 2)
  minOrderAmount  Decimal?     @db.Decimal(10, 2)
  maxDiscount     Decimal?     @db.Decimal(10, 2)
  usageLimit      Int?
  usedCount       Int          @default(0)
  validFrom       DateTime
  validUntil      DateTime
  active          Boolean      @default(true)
  sellerId        String?
  seller          Seller?      @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  orders          Order[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([sellerId])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

// Blog System
model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?  @db.Text
  content       String   @db.Text
  featuredImage String?
  author        String?
  tags          String[]
  category      String?
  
  status        BlogStatus @default(DRAFT)
  featured      Boolean    @default(false)
  
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// Gift Cards
model GiftCard {
  id            String   @id @default(cuid())
  code          String   @unique
  initialValue  Decimal  @db.Decimal(10, 2)
  currentValue  Decimal  @db.Decimal(10, 2)
  currency      String   @default("UGX")
  
  purchaserEmail String?
  purchaserName  String?
  recipientEmail String?
  recipientName  String?
  message        String?  @db.Text
  
  isActive      Boolean  @default(true)
  expiresAt     DateTime?
  
  redemptions   GiftCardRedemption[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GiftCardRedemption {
  id          String   @id @default(cuid())
  giftCardId  String
  giftCard    GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  orderId     String?
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
}

// Promotional Banners
model Banner {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  imageUrl      String
  mobileImageUrl String?
  linkUrl       String?
  buttonText    String?
  
  position      String   @default("home-hero") // home-hero, home-secondary, category-top
  sortOrder     Int      @default(0)
  
  isActive      Boolean  @default(true)
  startDate     DateTime?
  endDate       DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Enums
enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
  MANAGER
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  PENDING_REVIEW
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  MOBILE_MONEY
  PAYPAL
  COD
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// Multi-currency Support
model Currency {
  id            String   @id @default(cuid())
  code          String   @unique // USD, UGX, KES, TZS
  name          String   // US Dollar, Ugandan Shilling
  symbol        String   // $, USh, KSh, TSh
  exchangeRate  Decimal  @db.Decimal(15, 6) // Rate to base currency (UGX)
  isBase        Boolean  @default(false)
  isActive      Boolean  @default(true)
  decimalPlaces Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Payment Providers (Mobile Money, etc.)
model PaymentProvider {
  id            String   @id @default(cuid())
  name          String   // MTN Mobile Money, Airtel Money
  code          String   @unique // mtn_ug, airtel_ug, flutterwave
  type          PaymentProviderType
  
  // API Configuration (encrypted in practice)
  apiKey        String?
  apiSecret     String?
  merchantId    String?
  callbackUrl   String?
  
  // Supported currencies
  currencies    String[] // ["UGX", "USD"]
  
  // Fees
  feeType       DiscountType @default(PERCENTAGE)
  feeValue      Decimal   @db.Decimal(10, 4) @default(0)
  minFee        Decimal?  @db.Decimal(10, 2)
  maxFee        Decimal?  @db.Decimal(10, 2)
  
  isActive      Boolean  @default(true)
  isTest        Boolean  @default(true) // Test/sandbox mode
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Mobile Money Transactions
model MobileMoneyTransaction {
  id              String   @id @default(cuid())
  orderId         String?
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  
  provider        String   // mtn_ug, airtel_ug
  phoneNumber     String
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("UGX")
  
  externalRef     String?  // Provider's reference
  transactionId   String?  // Provider's transaction ID
  
  status          MobileMoneyStatus @default(PENDING)
  statusMessage   String?
  
  initiatedAt     DateTime @default(now())
  completedAt     DateTime?
  
  @@index([orderId])
  @@index([externalRef])
}

enum PaymentProviderType {
  MOBILE_MONEY
  CARD
  BANK_TRANSFER
  WALLET
}

enum MobileMoneyStatus {
  PENDING
  PROCESSING
  SUCCESSFUL
  FAILED
  CANCELLED
  TIMEOUT
}

// Webhook Idempotency Tracking
model ProcessedWebhook {
  id          String   @id @default(cuid())
  webhookId   String   @unique // Unique identifier from webhook payload (e.g., flw_ref)
  provider    String   // flutterwave, etc.
  eventType   String   // charge.completed, etc.
  processedAt DateTime @default(now())
  
  @@index([provider, webhookId])
}

// Checkout Idempotency Tracking (database-backed primary defense)
// Prevents duplicate orders when Redis is unavailable
model CheckoutAttempt {
  id              String   @id @default(cuid())
  userId          String?  // Null for guest checkout
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  idempotencyKey  String   // Client-supplied unique key
  orderId         String?  // Set after order is successfully created
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED
  createdAt       DateTime @default(now())
  expiresAt       DateTime // Cleanup after 24 hours to prevent unbounded growth
  
  @@unique([idempotencyKey])
  @@index([userId, createdAt])
  @@index([expiresAt])
}

// Activity Log for Admin Audit Trail
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  entityType  String   // Product, Order, User, Coupon, etc.
  entityId    String?  // ID of the affected entity
  description String   // Human-readable description
  metadata    Json?    // Additional data (old values, new values, etc.)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// Return/Refund System
model ReturnRequest {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  reason        ReturnReason
  description   String?       @db.Text
  status        ReturnStatus  @default(PENDING)
  
  // Admin response
  adminNotes    String?       @db.Text
  sellerNotes   String?       @db.Text
  refundAmount  Decimal?      @db.Decimal(10, 2)
  refundMethod  String?       // original_payment, store_credit, bank_transfer
  
  // Tracking
  returnLabel   String?       // Return shipping label URL
  trackingNumber String?
  
  // Items being returned
  items         ReturnItem[]
  
  processedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model ReturnItem {
  id              String        @id @default(cuid())
  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItemId     String
  quantity        Int
  reason          String?
  condition       String?       // unopened, opened, damaged
  
  @@index([returnRequestId])
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CHANGED_MIND
  ARRIVED_LATE
  OTHER
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  SHIPPED
  RECEIVED
  REFUNDED
  CLOSED
}

// Support Ticket System
model SupportTicket {
  id            String        @id @default(cuid())
  ticketNumber  String        @unique
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  email         String
  name          String
  subject       String
  category      TicketCategory
  priority      TicketPriority @default(MEDIUM)
  status        TicketStatus   @default(OPEN)
  
  orderId       String?       // Related order if applicable
  
  messages      TicketMessage[]
  
  assignedTo    String?       // Admin user ID
  resolvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([ticketNumber])
}

model TicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  senderId    String?       // User ID (null for customer if guest)
  senderType  String        // customer, admin
  senderName  String
  message     String        @db.Text
  attachments String[]      // URLs to attachments
  
  isInternal  Boolean       @default(false) // Internal admin notes
  
  createdAt   DateTime      @default(now())
  
  @@index([ticketId])
}

enum TicketCategory {
  ORDER_ISSUE
  SHIPPING
  RETURNS
  PAYMENT
  PRODUCT_INQUIRY
  TECHNICAL
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

// Loyalty Points System
model LoyaltyAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  points        Int      @default(0)
  lifetimePoints Int     @default(0)
  tier          LoyaltyTier @default(BRONZE)
  
  transactions  LoyaltyTransaction[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LoyaltyTransaction {
  id            String          @id @default(cuid())
  accountId     String
  account       LoyaltyAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  type          LoyaltyTxType
  points        Int             // Positive for earn, negative for redeem
  description   String
  
  orderId       String?         // Related order
  expiresAt     DateTime?       // Points expiry
  
  createdAt     DateTime        @default(now())
  
  @@index([accountId])
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoyaltyTxType {
  PURCHASE_EARN
  REFERRAL_BONUS
  SIGNUP_BONUS
  REDEMPTION
  EXPIRY
  ADJUSTMENT
}

// Referral System
model ReferralCode {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  code          String   @unique
  usageCount    Int      @default(0)
  totalEarnings Decimal  @default(0) @db.Decimal(10, 2)
  
  referrals     Referral[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Referral {
  id              String       @id @default(cuid())
  referralCodeId  String
  referralCode    ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  
  referredUserId  String       @unique
  referredUser    User         @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  
  status          ReferralStatus @default(PENDING)
  rewardAmount    Decimal?     @db.Decimal(10, 2)
  rewardPaid      Boolean      @default(false)
  
  firstOrderId    String?      // The qualifying order
  firstOrderAt    DateTime?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([referralCodeId])
}

enum ReferralStatus {
  PENDING       // Signed up but no order
  QUALIFIED     // Made first order
  REWARDED      // Reward given to referrer
  EXPIRED
}

// Abandoned Cart Tracking
model AbandonedCart {
  id            String   @id @default(cuid())
  cartId        String   @unique
  userId        String?
  email         String?
  
  cartData      Json     // Snapshot of cart items
  cartValue     Decimal  @db.Decimal(10, 2)
  currency      String   @default("UGX")
  
  // Email tracking
  email1SentAt  DateTime?
  email2SentAt  DateTime?
  email3SentAt  DateTime?

  // WhatsApp tracking
  whatsapp1SentAt DateTime?
  couponCode      String?

  recoveredAt   DateTime?
  recoveredOrderId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([email])
  @@index([createdAt])
}

// Two-Factor Authentication
model TwoFactorAuth {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  secret        String   // Encrypted TOTP secret
  isEnabled     Boolean  @default(false)
  
  // Backup codes
  backupCodes   String[] // Hashed backup codes
  
  // Recovery
  lastUsedAt    DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Stock Alerts (back-in-stock notifications) ───────────────────────────────
model StockAlert {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  email     String
  userId    String?
  notified  Boolean  @default(false)
  notifiedAt DateTime?
  createdAt DateTime @default(now())

  @@unique([productId, email])
  @@index([productId, notified])
}

// ─── Webhook Retry Queue ──────────────────────────────────────────────────────
model WebhookRetry {
  id          String   @id @default(cuid())
  provider    String
  eventType   String
  payload     Json
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  nextRetryAt DateTime @default(now())
  lastError   String?  @db.Text
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([resolved, nextRetryAt])
}

// ─── Fraud Log ────────────────────────────────────────────────────────────────
model FraudLog {
  id          String   @id @default(cuid())
  ipAddress   String
  userId      String?
  action      String   // login_attempt, order_placed, coupon_abuse, etc.
  riskScore   Int      @default(0) // 0-100
  reason      String?
  metadata    Json?
  blocked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([ipAddress, createdAt])
  @@index([userId])
}

// ─── Shipping Zones ───────────────────────────────────────────────────────────
model ShippingZone {
  id          String   @id @default(cuid())
  name        String   // e.g. "Kampala", "Upcountry", "International"
  countries   String[] // ISO codes or region names
  cities      String[] // specific cities
  rate        Decimal  @db.Decimal(10, 2)
  currency    String   @default("UGX")
  freeAbove   Decimal? @db.Decimal(10, 2) // Free shipping threshold
  estimatedDays String? // e.g. "1-2 days"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Tax Rules ────────────────────────────────────────────────────────────────
model TaxRule {
  id          String   @id @default(cuid())
  name        String   // e.g. "Uganda VAT"
  country     String
  region      String?
  rate        Decimal  @db.Decimal(5, 4) // e.g. 0.18 = 18%
  isInclusive Boolean  @default(false) // price already includes tax
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Frequently Bought Together ───────────────────────────────────────────────
model ProductRelation {
  id          String   @id @default(cuid())
  productId   String
  relatedId   String
  score       Int      @default(1) // How often bought together
  updatedAt   DateTime @updatedAt

  @@unique([productId, relatedId])
  @@index([productId, score])
}

// ─── Page Views (Visitor Tracking) ────────────────────────────────────────────
model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  sessionId String?
  ipAddress String?
  country   String?
  region    String?
  city      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([country])
}

// ─── Affiliate Marketing System ──────────────────────────────────────────────

// External affiliate products (Amazon, AliExpress, etc.) displayed on our site
model AffiliateProduct {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?  @db.Text
  price           Decimal  @db.Decimal(10, 2)
  originalPrice   Decimal? @db.Decimal(10, 2)
  currency        String   @default("USD")
  imageUrl        String?
  images          String[] // additional image URLs
  affiliateUrl    String   // the affiliate link to external store
  source          AffiliateSource
  sourceProductId String?  // external product ID (ASIN, AliExpress ID)
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            String[]
  rating          Decimal? @db.Decimal(3, 2)
  reviewCount     Int      @default(0)
  commissionRate  Decimal? @db.Decimal(5, 2) // expected commission %
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)

  clicks          AffiliateClick[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([source])
  @@index([isActive])
  @@index([categoryId])
}

// Track clicks on affiliate products
model AffiliateClick {
  id                 String   @id @default(cuid())
  affiliateProductId String
  affiliateProduct   AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)
  sessionId          String?
  ipAddress          String?
  userAgent          String?
  referrer           String?
  createdAt          DateTime @default(now())

  @@index([affiliateProductId])
  @@index([createdAt])
}

// Affiliates who promote OUR products (our affiliate program)
model Affiliate {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name            String
  email           String   @unique
  website         String?
  socialMedia     String?
  code            String   @unique  // unique affiliate code e.g. "BLOGGER123"
  commissionRate  Decimal  @default(10) @db.Decimal(5, 2) // percentage
  status          AffiliateStatus @default(PENDING)

  totalClicks     Int      @default(0)
  totalOrders     Int      @default(0)
  totalEarnings   Decimal  @default(0) @db.Decimal(12, 2)
  pendingPayout   Decimal  @default(0) @db.Decimal(12, 2)
  totalPaid       Decimal  @default(0) @db.Decimal(12, 2)

  conversions     AffiliateConversion[]
  payouts         AffiliatePayout[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Track sales attributed to an affiliate
model AffiliateConversion {
  id            String   @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  orderId       String
  orderAmount   Decimal  @db.Decimal(12, 2)
  commission    Decimal  @db.Decimal(12, 2)
  status        ConversionStatus @default(PENDING)
  paidAt        DateTime?

  createdAt     DateTime @default(now())

  @@index([affiliateId])
  @@index([orderId])
}

// Payout records
model AffiliatePayout {
  id            String   @id @default(cuid())
  affiliateId   String
  affiliate     Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(12, 2)
  method        String   // "mobile_money", "bank_transfer", etc.
  reference     String?
  notes         String?

  createdAt     DateTime @default(now())

  @@index([affiliateId])
}

enum AffiliateSource {
  AMAZON
  ALIEXPRESS
  ALIBABA
  MANUAL
}

enum AffiliateStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ConversionStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

// AliExpress Dropshipping
enum MarkupType {
  PERCENTAGE
  FIXED
}

enum AliExpressOrderStatus {
  PENDING        // Order not yet placed on AliExpress
  PLACED         // Order placed on AliExpress
  SHIPPED        // AliExpress supplier shipped
  DELIVERED      // Delivered to customer
  CANCELLED      // Cancelled on AliExpress
  FAILED         // Failed to place on AliExpress
}

model AliExpressOrder {
  id                  String               @id @default(cuid())
  orderId             String
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  aliexpressOrderId   String?              // AliExpress order number
  aliexpressProductId String               // AliExpress product ID
  quantity            Int
  supplierCost        Decimal              @db.Decimal(10, 2) // Price paid to AliExpress
  trackingNumber      String?
  trackingUrl         String?
  shippingCarrier     String?
  status              AliExpressOrderStatus @default(PENDING)
  errorMessage        String?              @db.Text
  placedAt            DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([orderId])
  @@index([aliexpressOrderId])
  @@index([status])
}

// CJ Dropshipping
enum CJOrderStatus {
  PENDING
  PLACED
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
}

model CJOrder {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  cjOrderId       String?       // CJ Dropshipping order ID
  cjProductId     String        // CJ product ID
  quantity        Int
  supplierCost    Decimal       @db.Decimal(10, 2)
  trackingNumber  String?
  trackingUrl     String?
  shippingCarrier String?
  status          CJOrderStatus @default(PENDING)
  errorMessage    String?       @db.Text
  placedAt        DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([cjOrderId])
  @@index([status])
}

// ─── Back-in-Stock Notifications ──────────────────────────────────────────────
model BackInStockSub {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([productId, email])
  @@index([productId, notified])
}

// ─── Product Q&A ──────────────────────────────────────────────────────────────
model ProductQuestion {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question  String   @db.Text
  answers   ProductAnswer[]
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductAnswer {
  id         String   @id @default(cuid())
  questionId String
  question   ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer     String   @db.Text
  isOfficial Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([questionId])
}

// ─── Product Bundles ──────────────────────────────────────────────────────────
model ProductBundle {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  discount    Decimal  @db.Decimal(5, 2) // percentage discount
  isActive    Boolean  @default(true)
  items       BundleItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BundleItem {
  id        String   @id @default(cuid())
  bundleId  String
  bundle    ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)

  @@unique([bundleId, productId])
}

// ─── Bulk / Tiered Pricing ────────────────────────────────────────────────────
model PriceTier {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQty    Int
  discount  Decimal  @db.Decimal(5, 2) // percentage off
  label     String?  // e.g. "Buy 3+ save 10%"

  @@unique([productId, minQty])
  @@index([productId])
}

// ─── Store Credit / Wallet ────────────────────────────────────────────────────
model StoreCredit {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Decimal  @default(0) @db.Decimal(10, 2)
  transactions StoreCreditTx[]
  updatedAt    DateTime @updatedAt
}

model StoreCreditTx {
  id            String   @id @default(cuid())
  storeCreditId String
  storeCredit   StoreCredit @relation(fields: [storeCreditId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(10, 2) // positive = credit, negative = debit
  type          String   // REFUND, MANUAL, PURCHASE, REDEMPTION
  description   String?
  orderId       String?
  createdAt     DateTime @default(now())

  @@index([storeCreditId])
}

// ─── Installment / Buy Now Pay Later ──────────────────────────────────────────
model InstallmentPlan {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  totalAmount  Decimal  @db.Decimal(10, 2)
  installments Int      // 2, 3, or 4
  paidCount    Int      @default(1) // first installment paid at checkout
  nextDueDate  DateTime
  status       String   @default("ACTIVE") // ACTIVE, COMPLETED, OVERDUE, CANCELLED
  payments     InstallmentPayment[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model InstallmentPayment {
  id         String   @id @default(cuid())
  planId     String
  plan       InstallmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  number     Int      // installment number (1, 2, 3, 4)
  amount     Decimal  @db.Decimal(10, 2)
  status     String   @default("PENDING") // PENDING, PAID, OVERDUE
  dueDate    DateTime
  paidAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([planId])
}

// ─── Subscriptions / Auto-Replenish ───────────────────────────────────────────
model Subscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int      @default(1)
  intervalDays Int     @default(30) // 14, 30, 60, 90
  discount    Decimal  @db.Decimal(5, 2) // percentage off
  nextDelivery DateTime
  status      String   @default("ACTIVE") // ACTIVE, PAUSED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
  @@index([nextDelivery, status])
}

// ─── Web Push Notifications ───────────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Browse Events (for abandonment emails & personalization) ─────────────────
model BrowseEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@index([userId, viewedAt])
  @@index([productId])
}

// ─── Webhook Integrations ─────────────────────────────────────────────────────
model WebhookEndpoint {
  id        String   @id @default(cuid())
  url       String
  events    String[] // ORDER_CREATED, ORDER_SHIPPED, PAYMENT_RECEIVED, etc.
  secret    String   // HMAC signing secret
  isActive  Boolean  @default(true)
  failCount Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Social Shopping: Share for Discount ──────────────────────────────────────
model ShareDiscount {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shareCode  String   @unique
  platform   String   // whatsapp, facebook, twitter, copy
  clicks     Int      @default(0)
  couponCode String?  @unique
  couponUsed Boolean  @default(false)
  discount   Int      @default(10) // percentage off
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([shareCode])
}

// ─── Social Shopping: Group Buy ───────────────────────────────────────────────
model GroupBuy {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  targetCount     Int      @default(3)
  currentCount    Int      @default(0)
  discountPercent Int      @default(20)
  groupPrice      Decimal  @db.Decimal(10, 2)
  expiresAt       DateTime
  status          String   @default("active") // active, completed, expired
  createdAt       DateTime @default(now())
  participants    GroupBuyParticipant[]

  @@index([productId])
  @@index([status, expiresAt])
}

model GroupBuyParticipant {
  id         String   @id @default(cuid())
  groupBuyId String
  groupBuy   GroupBuy @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt   DateTime @default(now())

  @@unique([groupBuyId, userId])
}

// ─── Social Shopping: Daily Check-in ──────────────────────────────────────────
model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  points    Int      @default(10)
  streak    Int      @default(1)
  bonus     Int      @default(0) // bonus points for streak milestones
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Social Shopping: Price Slash ─────────────────────────────────────────────
model PriceSlash {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  initiatorId    String
  initiator      User     @relation(fields: [initiatorId], references: [id], onDelete: Cascade)
  slashCode      String   @unique
  originalPrice  Decimal  @db.Decimal(10, 2)
  currentPrice   Decimal  @db.Decimal(10, 2)
  minPrice       Decimal  @db.Decimal(10, 2)
  slashAmount    Decimal  @default(500) @db.Decimal(10, 2)
  maxSlashes     Int      @default(10)
  currentSlashes Int      @default(0)
  expiresAt      DateTime
  status         String   @default("active") // active, claimed, expired
  createdAt      DateTime @default(now())
  slashers       PriceSlasher[]

  @@index([slashCode])
  @@index([initiatorId])
}

model PriceSlasher {
  id           String     @id @default(cuid())
  priceSlashId String
  priceSlash   PriceSlash @relation(fields: [priceSlashId], references: [id], onDelete: Cascade)
  visitorIp    String
  slashedAt    DateTime   @default(now())

  @@unique([priceSlashId, visitorIp])
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   @unique // SHA-256 hash of the API key
  prefix      String            // First 12 chars for display (e.g. "sk_live_a3f1...")

  permissions String[]

  userId      String?

  rateLimit   Int      @default(100)

  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  requestCount Int     @default(0)

  ipWhitelist String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime?

  @@index([keyHash])
  @@index([userId])
}

// ═══════════════════════════════════════════════════
// MARKETPLACE / MULTI-VENDOR
// ═══════════════════════════════════════════════════

model Seller {
  id            String       @id @default(cuid())
  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business info
  storeName     String       @unique
  storeSlug     String       @unique
  description   String?      @db.Text
  logo          String?
  banner        String?
  phone         String?
  email         String?
  website       String?

  // Location
  address       String?
  city          String?
  country       String?      @default("UG")

  // Verification
  status        SellerStatus @default(PENDING)
  tier          SellerTier   @default(BRONZE)
  verifiedAt    DateTime?
  rejectionNote String?
  idDocument    String?      // Path to uploaded ID document
  businessLicense String?    // Path to business license

  // Financial
  commissionRate Decimal?    @db.Decimal(5, 2) // Override per-seller, null = use category/default
  balance       Decimal      @default(0) @db.Decimal(12, 2) // Available balance for withdrawal
  totalEarnings Decimal      @default(0) @db.Decimal(12, 2)
  totalSales    Int          @default(0)

  // Payout info
  payoutMethod  PayoutMethod? @default(MOBILE_MONEY)
  payoutPhone   String?       // Mobile money number
  bankName      String?
  bankAccount   String?
  bankBranch    String?

  // Settings
  autoApproveProducts Boolean @default(false) // Skip product review for trusted sellers
  rating        Decimal      @default(0) @db.Decimal(2, 1)
  reviewCount   Int          @default(0)

  products      Product[]
  orderItems    OrderItem[]
  payouts       SellerPayout[]
  reviews       SellerReview[]
  conversations Conversation[]
  warnings      SellerWarning[]
  promotions    ProductPromotion[]
  adTransactions AdTransaction[]
  badges        SellerBadge[]
  disputes      Dispute[]
  coupons       Coupon[]

  // Extended settings
  socialLinks       Json?
  operatingHours    Json?
  shippingPolicy    String?   @db.Text
  returnPolicy      String?   @db.Text
  notificationPrefs Json?

  // Ad balance (separate from earnings balance)
  adBalance     Decimal      @default(0) @db.Decimal(12, 2)
  onboardingCompleted Boolean @default(false)

  // Trust metrics
  trustScore      Int          @default(0)     // 0-100
  avgShipDays     Decimal?     @db.Decimal(4, 1) // Average days to ship
  onTimeRate      Decimal?     @db.Decimal(5, 2) // % of orders shipped on time
  responseRate    Decimal?     @db.Decimal(5, 2) // % of messages responded
  avgResponseHrs  Decimal?     @db.Decimal(6, 1) // Average hours to respond
  disputeRate     Decimal?     @db.Decimal(5, 2) // % of orders with disputes
  returnRate      Decimal?     @db.Decimal(5, 2) // % of orders with returns

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([storeSlug])
}

enum SellerStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum SellerTier {
  BRONZE
  SILVER
  GOLD
}

enum PayoutMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  FLUTTERWAVE
}

model CommissionRule {
  id          String   @id @default(cuid())
  categoryId  String?  @unique // null = default rule for all categories
  categoryName String? // Denormalized for display
  rate        Decimal  @db.Decimal(5, 2) // Percentage (e.g. 15.00 = 15%)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SellerPayout {
  id          String        @id @default(cuid())
  sellerId    String
  seller      Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("UGX")
  method      PayoutMethod
  reference   String?       // Transaction reference
  status      PayoutStatus  @default(PENDING)
  processedAt DateTime?
  processedBy String?       // Admin who processed
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([sellerId])
  @@index([status])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

// ─── Buyer-Seller Chat ────────────────────────────────────────────────────────
model Conversation {
  id            String        @id @default(cuid())
  buyerId       String?
  buyer         User?         @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  adminId       String?
  lastMessageAt DateTime      @default(now())
  createdAt     DateTime      @default(now())
  messages      ChatMessage[]

  @@index([buyerId, sellerId])
  @@index([sellerId])
  @@index([adminId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderType     SenderType
  message        String       @db.Text
  attachment     String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

enum SenderType {
  BUYER
  SELLER
  ADMIN
}

model SellerReview {
  id        String   @id @default(cuid())
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  userId    String?
  userName  String
  rating    Int      // 1-5
  comment   String?  @db.Text
  orderId   String?  // Which order this review is for
  createdAt DateTime @default(now())

  @@index([sellerId])
}

model SellerWarning {
  id             String      @id @default(cuid())
  sellerId       String
  seller         Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type           WarningType
  reason         String      @db.Text
  issuedBy       String      // Admin user ID
  acknowledgedAt DateTime?
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())

  @@index([sellerId])
  @@index([sellerId, expiresAt])
}

enum WarningType {
  WARNING
  STRIKE
  FINAL_WARNING
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  category    String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String   @id @default(cuid())
  role         UserRole
  permissionId String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

// ─── Bridal/Kwanjula Registry ─────────────────────────────────────────────────

model Registry {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String         @unique  // shareable URL token
  title       String         // e.g. "Elvis & Aisha's Introduction"
  eventDate   DateTime?
  eventType   String         @default("introduction") // introduction, wedding, anniversary, birthday
  message     String?        @db.Text
  isPublic    Boolean        @default(false)
  isActive    Boolean        @default(true)
  items       RegistryItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([slug])
}

model RegistryItem {
  id          String   @id @default(cuid())
  registryId  String
  registry    Registry @relation(fields: [registryId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int      @default(1)
  purchased   Int      @default(0)
  priority    String   @default("medium") // high, medium, low
  note        String?
  createdAt   DateTime @default(now())

  @@index([registryId])
  @@index([productId])
}

// ─── Auto-Restock Reminder ────────────────────────────────────────────────────

model RestockReminder {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId     String?   // The original order that triggered this
  remindAt    DateTime  // When to send the reminder
  sent        Boolean   @default(false)
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([remindAt, sent])
  @@index([userId])
}

// ─── Price Drop Alerts ──────────────────────────────────────────────────────
model PriceDropAlert {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  email       String?
  phone       String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetPrice Decimal  @db.Decimal(10, 2)
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([productId, email])
  @@unique([productId, phone])
  @@index([productId, notified])
}

// ─── Sponsored Ads ──────────────────────────────────────────────────────────

enum PromotionTier {
  BASIC
  PREMIUM
  VIP
}

enum PromotionStatus {
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED
}

enum AdTransactionType {
  FUND
  DEBIT
  REFUND
}

model ProductPromotion {
  id         String          @id @default(cuid())
  sellerId   String
  seller     Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  tier       PromotionTier
  status     PromotionStatus @default(ACTIVE)
  startDate  DateTime        @default(now())
  endDate    DateTime
  dailyRate  Decimal         @db.Decimal(10, 2)
  totalBudget Decimal        @db.Decimal(10, 2)
  spent      Decimal         @default(0) @db.Decimal(10, 2)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([sellerId])
  @@index([productId])
  @@index([status, endDate])
}

model AdTransaction {
  id           String            @id @default(cuid())
  sellerId     String
  seller       Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type         AdTransactionType
  amount       Decimal           @db.Decimal(10, 2)
  reference    String?
  description  String?
  balanceAfter Decimal           @db.Decimal(12, 2)
  createdAt    DateTime          @default(now())

  @@index([sellerId])
  @@index([createdAt])
}

// ─── Buyer Protection / Escrow ──────────────────────────────────────────────────
model EscrowTransaction {
  id            String        @id @default(cuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Decimal       @db.Decimal(12, 2) // Total amount held in escrow
  currency      String        @default("UGX")
  status        EscrowStatus  @default(HELD)

  // Timing
  heldAt        DateTime      @default(now())
  releaseDate   DateTime      // Auto-release date (e.g., 7 days after DELIVERED)
  releasedAt    DateTime?

  // Resolution
  releasedTo    String?       // Seller ID who received funds
  refundedTo    String?       // Buyer user ID if refunded
  disputeId     String?       // If released via dispute resolution
  notes         String?       @db.Text

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([releaseDate])
}

enum EscrowStatus {
  HELD          // Payment captured, funds held
  RELEASING     // Auto-release triggered, processing
  RELEASED      // Funds released to seller
  DISPUTED      // Dispute opened, funds frozen
  REFUNDED      // Funds returned to buyer
  PARTIAL_REFUND // Partial refund issued
}

// ─── Dispute Resolution ─────────────────────────────────────────────────────────
model Dispute {
  id            String          @id @default(cuid())
  disputeNumber String          @unique // e.g., DSP-20260530-001
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User            @relation("BuyerDisputes", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId      String
  seller        Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  // Dispute details
  category      DisputeCategory
  reason        String          @db.Text
  status        DisputeStatus   @default(OPEN)
  priority      DisputePriority @default(MEDIUM)

  // Evidence
  evidence      DisputeEvidence[]
  messages      DisputeMessage[]

  // Seller response
  sellerResponse   String?      @db.Text
  sellerRespondedAt DateTime?

  // Admin resolution
  assignedTo    String?         // Admin user ID
  resolution    DisputeResolution?
  resolutionNote String?        @db.Text
  refundAmount  Decimal?        @db.Decimal(12, 2) // Amount refunded if applicable
  resolvedBy    String?         // Admin user ID
  resolvedAt    DateTime?

  // Deadlines
  sellerDeadline DateTime?      // Seller must respond by this date
  escalatedAt    DateTime?      // When escalated to admin

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

model DisputeEvidence {
  id          String   @id @default(cuid())
  disputeId   String
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploadedBy  String   // User ID
  type        String   // photo, video, screenshot, document
  fileUrl     String
  fileName    String
  description String?
  createdAt   DateTime @default(now())

  @@index([disputeId])
}

model DisputeMessage {
  id          String   @id @default(cuid())
  disputeId   String
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId    String
  senderType  String   // BUYER, SELLER, ADMIN
  senderName  String
  message     String   @db.Text
  isInternal  Boolean  @default(false) // Admin-only notes
  createdAt   DateTime @default(now())

  @@index([disputeId, createdAt])
}

enum DisputeCategory {
  NOT_RECEIVED
  DAMAGED
  NOT_AS_DESCRIBED
  WRONG_ITEM
  MISSING_ITEMS
  DEFECTIVE
  COUNTERFEIT
  QUALITY_ISSUE
  OTHER
}

enum DisputeStatus {
  OPEN              // Buyer filed dispute
  SELLER_RESPONSE   // Waiting for seller response
  UNDER_REVIEW      // Admin reviewing
  EVIDENCE_REQUESTED // More evidence needed
  RESOLVED          // Resolution applied
  CLOSED            // Closed (no further action)
  ESCALATED         // Escalated to senior admin
}

enum DisputePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DisputeResolution {
  BUYER_FULL_REFUND      // Full refund to buyer
  BUYER_PARTIAL_REFUND   // Partial refund to buyer
  BUYER_REPLACEMENT      // Seller sends replacement
  SELLER_WINS            // No refund, seller keeps payment
  MUTUAL_AGREEMENT       // Custom resolution
  CANCELLED              // Dispute withdrawn by buyer
}

// ─── Seller Trust Badges ────────────────────────────────────────────────────────
model SellerBadge {
  id          String   @id @default(cuid())
  sellerId    String
  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  badge       BadgeType
  earnedAt    DateTime @default(now())
  expiresAt   DateTime? // Some badges need re-qualification
  isActive    Boolean  @default(true)

  @@unique([sellerId, badge])
  @@index([sellerId, isActive])
}

enum BadgeType {
  VERIFIED           // ID & business docs verified
  TOP_RATED          // Rating >= 4.5 with 50+ reviews
  FAST_SHIPPER       // Ships within 24hrs consistently
  RESPONSIVE         // Responds to messages within 2hrs
  TRUSTED            // 100+ completed orders, low dispute rate
  PREMIUM            // All badges earned + GOLD tier
  NEW_SELLER         // First 30 days
  RISING_STAR        // Fast-growing seller metrics
}

// ─── Layaway / Micro-Subscriptions ───────────────────────────────────────────
model LayawayPlan {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  targetAmount      Decimal  @db.Decimal(10, 2)
  paidAmount        Decimal  @default(0) @db.Decimal(10, 2)
  frequency         String   // DAILY, WEEKLY, BIWEEKLY
  installmentAmount Decimal  @db.Decimal(10, 2)
  status            String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, EXPIRED
  completedAt       DateTime?
  orderId           String?  // Created when plan completes
  nextPaymentDate   DateTime
  payments          LayawayPayment[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextPaymentDate])
}

model LayawayPayment {
  id        String   @id @default(cuid())
  planId    String
  plan      LayawayPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(10, 2)
  status    String   @default("PENDING") // PENDING, PAID, FAILED
  flwRef    String?  // Flutterwave transaction reference
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
}
