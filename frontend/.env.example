# ── Vercel Environment Variables ──────────────────────────────────────────────
# Copy these into Vercel → Project → Settings → Environment Variables

# URL of your deployed Next.js frontend (Vercel gives you this)
NEXT_PUBLIC_API_URL=https://your-project.vercel.app

# URL of your deployed Express backend (Railway / Render / Fly.io)
BACKEND_URL=https://your-backend.railway.app

# Internal backend URL for server-side rendering (Docker: http://backend:4000)
INTERNAL_API_URL=http://localhost:4000

# Google Analytics
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Site URL
NEXT_PUBLIC_SITE_URL=https://ugsex.com
